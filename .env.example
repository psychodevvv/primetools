# Скопируйте этот файл в .env и заполните своими значениями.

# Сгенерировать ключ: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=твой-логин.pythonanywhere.com,localhost,127.0.0.1

# Telegram-бот для уведомлений о новых заказах (необязательно)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Контактные номера, отображаемые на сайте
CALL_NUMBER=+7 777 256 1177
WHATSAPP_NUMBER=77772561177

# SMS-шлюз для кодов подтверждения при регистрации.
# Если не заполнено — код показывается на экране (демо-режим, для разработки).
SMS_API_KEY=
SMS_API_URL=
SMS_SENDER=
